{
  "openapi": "3.0.1",
  "info": {
    "title": "Sesa API",
    "description": "API para la gestión de pólizas de seguro de vehículos",
    "version": "v1"
  },
  "paths": {
    "/api/coverage/create": {
      "post": {
        "tags": [
          "Coverage"
        ],
        "summary": "Registra un nuevo tipo de cobertura",
        "description": "Requiere los datos del tipo de cobertura. El nombre de la cobertura no puede estar duplicado en el sistema.",
        "operationId": "CreateCoverage",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCoverageDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tipo de cobertura registrado exitosamente"
          },
          "400": {
            "description": "No se pudo registrar el tipo de cobertura"
          }
        }
      }
    },
    "/api/coverage/update": {
      "put": {
        "tags": [
          "Coverage"
        ],
        "summary": "Actualiza un tipo de cobertura existente",
        "description": "Requiere los datos del tipo de cobertura",
        "operationId": "UpdateCoverage",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCoverageDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tipo de cobertura actualizado exitosamente"
          },
          "400": {
            "description": "Ocurrió un error actualizando el tipo de cobertura"
          },
          "404": {
            "description": "No se pudo encontrar el tipo de cobertura"
          }
        }
      }
    },
    "/api/coverage/get/{id}": {
      "get": {
        "tags": [
          "Coverage"
        ],
        "summary": "Obtiene un tipo de cobertura por su Id",
        "description": "Requiere el Id del tipo de cobertura",
        "operationId": "GetCoverageById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tipo de cobertura obtenido exitosamente"
          },
          "400": {
            "description": "Ocurrió un error obteniendo el tipo de cobertura"
          },
          "404": {
            "description": "No se pudo encontrar el tipo de cobertura"
          }
        }
      }
    },
    "/api/coverage/get": {
      "get": {
        "tags": [
          "Coverage"
        ],
        "summary": "Obtiene todos los tipos de coberturas",
        "description": "Obtiene un listado de todos los tipos de coberturas",
        "operationId": "GetCoverages",
        "responses": {
          "200": {
            "description": "Tipos de coberturas obtenidos exitosamente"
          },
          "400": {
            "description": "Ocurrió un error buscando los tipos de coberturas"
          }
        }
      }
    },
    "/api/coverage/delete": {
      "put": {
        "tags": [
          "Coverage"
        ],
        "summary": "Elimina un tipo de cobertura",
        "description": "Elimina un tipo de cobertura existente (Se hace borrado lógico cambiando a 0 el valor de la columna IsActive)",
        "operationId": "DeleteCoverage",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tipo de cobertura eliminado exitosamente"
          },
          "400": {
            "description": "Ocurrió un error eliminando el tipo de cobertura"
          },
          "404": {
            "description": "No se encontró el tipo de cobertura"
          }
        }
      }
    },
